{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "./dist",
  "routes": [
    {
      "path": "/api/*",
      "target": "./edge-functions"
    },
    {
      "path": "/*",
      "target": "./dist"
    }
  ],
  "edgeFunctions": {
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/index.js"
      }
    ]
  },
  "envVariables": {
    "JWT_SECRET": "academic-hub-v4-jwt-secret-key-2026-prod-min"
  },
  "site": {
    "icp": {
      "number": "粤ICP备2026052655号-1",
      "link": "https://beian.miit.gov.cn/"
    }
  }
}
